# AI Report Generator - Environment Configuration

# Server configuration
HOST=0.0.0.0
PORT=8080
RUST_LOG=info

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/ai_report

# Redis (for real-time market data)
REDIS_URL=redis://127.0.0.1/6379

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key-here

# Scheduler configuration
ENABLE_AUTO_REPORT_SCHEDULER=true
MAX_REPORT_ATTEMPTS=3

# External API Keys (optional)
COINGECKO_API_KEY=your-coingecko-api-key
TAAPI_API_KEY=your-taapi-api-key
